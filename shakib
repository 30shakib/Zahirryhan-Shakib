<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Zahirryhan Shakib | Firebase Website</title>

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

  <!-- Firebase -->
  <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-auth-compat.js"></script>

  <style>
    body{
      margin:0;
      font-family:Poppins;
      background-size:cover;
      background-position:center;
      transition:2s;
      background-color:#f4f4f4;
    }

    header{
      text-align:center;
      padding:40px;
      color:white;
      background:linear-gradient(135deg,#4f46e5,#9333ea);
    }

    .container{
      max-width:900px;
      margin:20px auto;
      background:white;
      padding:20px;
      border-radius:12px;
    }

    input{
      width:100%;
      padding:10px;
      margin-top:10px;
      border-radius:8px;
    }

    button{
      width:100%;
      padding:10px;
      margin-top:10px;
      background:#4f46e5;
      color:white;
      border:none;
      border-radius:8px;
      cursor:pointer;
    }

    #dashboard{display:none;}

    .card{
      background:#f3f4f6;
      padding:10px;
      margin-top:10px;
      border-radius:8px;
    }
  </style>
</head>

<body>

<header>
  <h1>Zahirryhan Shakib Website</h1>
  <p>Secure Firebase Login + AI Portfolio</p>
</header>

<!-- LOGIN -->
<div class="container" id="loginBox">
  <h2>Login System</h2>

  <input id="email" placeholder="Email">
  <input id="password" type="password" placeholder="Password">

  <button onclick="signup()">Sign Up</button>
  <button onclick="login()">Login</button>

  <hr>

  <button onclick="googleLogin()">Login with Google</button>

  <hr>

  <input id="phone" placeholder="Phone (+880...)">
  <div id="recaptcha"></div>
  <button onclick="sendOTP()">Send OTP</button>

  <input id="otp" placeholder="Enter OTP">
  <button onclick="verifyOTP()">Verify OTP</button>
</div>

<!-- DASHBOARD -->
<div class="container" id="dashboard">
  <h2>Dashboard</h2>
  <p id="userInfo"></p>

  <div class="card">✔ Firebase Auth Active</div>
  <div class="card">✔ Secure Login System</div>
  <div class="card">✔ Portfolio Dashboard</div>

  <button onclick="logout()">Logout</button>
</div>

<script>
/* 🔥 FIREBASE CONFIG (replace yours) */
const firebaseConfig = {
  apiKey: "YOUR_API_KEY",
  authDomain: "YOUR_AUTH_DOMAIN",
  projectId: "YOUR_PROJECT_ID",
  appId: "YOUR_APP_ID"
};

firebase.initializeApp(firebaseConfig);
const auth = firebase.auth();

/* SIGN UP */
function signup(){
  auth.createUserWithEmailAndPassword(email.value,password.value)
  .then(()=>alert("Account Created"))
  .catch(e=>alert(e.message));
}

/* LOGIN */
function login(){
  auth.signInWithEmailAndPassword(email.value,password.value)
  .then(u=>show(u.user))
  .catch(e=>alert(e.message));
}

/* GOOGLE LOGIN */
function googleLogin(){
  let provider = new firebase.auth.GoogleAuthProvider();
  auth.signInWithPopup(provider).then(r=>show(r.user));
}

/* OTP LOGIN */
function sendOTP(){
  window.recaptchaVerifier =
    new firebase.auth.RecaptchaVerifier('recaptcha',{size:'invisible'});

  auth.signInWithPhoneNumber(phone.value, window.recaptchaVerifier)
  .then(c=>{
    window.confirmationResult=c;
    alert("OTP Sent");
  });
}

function verifyOTP(){
  confirmationResult.confirm(otp.value)
  .then(r=>show(r.user))
  .catch(()=>alert("Wrong OTP"));
}

/* DASHBOARD */
function show(user){
  loginBox.style.display="none";
  dashboard.style.display="block";

  userInfo.innerText =
    "Logged in: " + (user.email || user.phoneNumber);
}

/* LOGOUT */
function logout(){
  auth.signOut().then(()=>location.reload());
}

/* 🔄 Background slider (4D effect idea) */
const bg = [
 "https://images.unsplash.com/photo-1501785888041-af3ef285b470",
 "https://images.unsplash.com/photo-1497436072909-60f360e1d4b1",
 "https://images.unsplash.com/photo-1500530855697-b586d89ba3ee"
];

let i=0;
setInterval(()=>{
  document.body.style.backgroundImage = `url('${bg[i]}')`;
  i=(i+1)%bg.length;
},120000);

</script>

</body>
</html>
